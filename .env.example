# Oulipo Dashboard Environment Variables
# Copy this file to .env.local and fill in your values

# Dashboard authentication (single shared password)
DASHBOARD_PASSWORD=

# Anthropic Claude API
ANTHROPIC_API_KEY=

# OpenAI API (for GPT models in content publisher)
OPENAI_API_KEY=

# Google OAuth credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Local oulipo repo path (for events.json and HTML files)
OULIPO_REPO_PATH=/Users/halim/Documents/oulipo

# Supabase (consolidated oulipo-main project)
# Project: singulars (ref: smytgqkgomsfyurskpcl). Get key from Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://smytgqkgomsfyurskpcl.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Schema for events (oulipo_dashboard). Table name is "events".
SUPABASE_EVENTS_TABLE=events
SUPABASE_EVENTS_SCHEMA=oulipo_dashboard
